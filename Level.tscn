[sub_resource type="Shader" id="Shader_wwf52"]
code = "shader_type spatial;
render_mode cull_disabled;

uniform vec4 albedo : source_color = vec4(0.25, 0.72, 0.12, 1.0);
uniform sampler2D albedo_texture : source_color, filter_nearest_mipmap;
uniform float alpha_scissor_threshold : hint_range(0.0, 1.0) = 0.1;

void fragment() {
	vec4 tex_color = texture(albedo_texture, UV);
	ALBEDO = albedo.rgb * 1.25;
	EMISSION = albedo.rgb * 0.15;
	float alpha = tex_color.a;
	if (tex_color.a >= 0.99) {
		alpha = tex_color.r;
	}
	ALPHA = alpha;
	ALPHA_SCISSOR_THRESHOLD = alpha_scissor_threshold;
}"

